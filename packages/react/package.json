{
  "name": "@ogcio/design-system-react",
  "version": "1.34.0",
  "description": "The Government of Ireland Design System React components.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js",
    "./styles.css": "./dist/styles.css",
    "./fonts.css": "./fonts.css",
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./logos": {
      "types": "./dist/logos/index.d.ts",
      "import": "./dist/logos/index.js"
    }
  },
  "scripts": {
    "format": "prettier 'src/**/*.{ts,tsx}' --write",
    "format:check": "prettier 'src/**/*.{ts,tsx}' --check",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "build": "pnpm build:ts && pnpm build:styles",
    "build:styles": "tailwindcss -i ./styles.css -o ./dist/styles.css --minify && node scripts/build-styles.js",
    "build:ts": "vite build",
    "storybook:dev": "storybook dev -p 6006",
    "storybook:build": "NODE_OPTIONS=--max-old-space-size=4096 storybook build --stats-json",
    "playwright:test": "playwright test",
    "playwright:update-snapshots": "playwright test --update-snapshots",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "prettier": "@ogcio/design-system-prettier-config",
  "sideEffects": [
    "**/*.css",
    "./dist/browser-support/runtime.js"
  ],
  "files": [
    "dist",
    "styles",
    "fonts.css"
  ],
  "keywords": [],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  },
  "dependencies": {
    "@fontsource/lato": "^5.1.1",
    "@popperjs/core": "^2.11.8",
    "@radix-ui/react-slot": "^1.1.2",
    "bowser": "^2.13.1",
    "clsx": "^2.1.1",
    "focus-trap": "^7.8.0",
    "i18next": "^25.6.2",
    "lodash": "^4.17.23",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^16.3.3",
    "tailwind-variants": "^0.2.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@faker-js/faker": "^9.9.0",
    "@ogcio/design-system-prettier-config": "workspace:*",
    "@ogcio/design-system-tailwind": "workspace:*",
    "@ogcio/theme-doete": "workspace:*",
    "@ogcio/theme-govie": "workspace:*",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-coverage": "^3.0.1",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-table": "^8.21.3",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "autoprefixer": "^10.4.19",
    "axe-core": "^4.10.0",
    "eslint-plugin-storybook": "^10.2.19",
    "glob": "^11.0.1",
    "postcss": "^8.4.40",
    "postcss-import": "^16.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rollup-preserve-directives": "^1.1.2",
    "storybook": "^10.3.3",
    "storybook-addon-pseudo-states": "^10.3.3"
  }
}
