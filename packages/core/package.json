{
  "name": "@ogcio/design-system-core",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm run build:react && pnpm run build:angular",
    "build:react": "NODE_OPTIONS='--import tsx' mitosis build --config react.config.ts",
    "build:angular": "NODE_OPTIONS='--import tsx' mitosis build --config angular.config.ts",
    "build:watch": "chokidar \"./atoms/**/*.{ts,tsx}\" -c \"pnpm run build\" --initial",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@builder.io/mitosis": "^0.12.1",
    "@builder.io/mitosis-cli": "^0.12.1",
    "@prettier/sync": "^0.6.1",
    "chokidar-cli": "^3.0.0",
    "storybook": "^10.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  }
}
