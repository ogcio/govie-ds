{
  "name": "@ogcio/design-system-angular",
  "private": true,
  "version": "0.1.0",
  "description": "The Government of Ireland Design System Angular components.",
  "type": "module",
  "exports": {
    "./fonts.css": "./fonts.css",
    "./styles.css": "./styles.css"
  },
  "publishConfig": {
    "directory": "dist",
    "linkDirectory": true
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json && pnpm build:styles",
    "build:styles": "tailwindcss -i ./styles.css -o ./dist/styles.css --minify",
    "storybook:dev": "ng run design-system-angular:storybook",
    "storybook:build": "ng run design-system-angular:build-storybook",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "@angular/common": ">=19.0.0 <22.0.0",
    "@angular/core": ">=19.0.0 <22.0.0",
    "lodash": "^4.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@fontsource/lato": "^5.1.1",
    "@ogcio/design-system-tailwind": "workspace:*",
    "@ogcio/theme-govie": "workspace:*",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-coverage": "^3.0.1",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/angular": "^10.3.3",
    "@tailwindcss/typography": "^0.5.16",
    "@types/lodash": "^4.17.7",
    "@types/postcss-import": "^14.0.3",
    "autoprefixer": "^10.4.23",
    "lodash": "^4.18.1",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.14",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.1",
    "storybook": "^10.3.3",
    "storybook-addon-pseudo-states": "^10.3.3",
    "tailwindcss": "3.4.14",
    "typescript": "^5.9.3"
  }
}
